# Planet Commander Environment Configuration
# Copy to .env and customize

# Database (Planet Operations Database)
PLANET_OPS_DATABASE_URL=postgresql+asyncpg://planet_ops:planet_ops_local@localhost:9432/planet_ops
PLANET_OPS_DATABASE_URL_SYNC=postgresql://planet_ops:planet_ops_local@localhost:9432/planet_ops

# Claude Code paths (defaults to ~/.<name>)
# PLANET_OPS_CLAUDE_DIR=~/.claude
# PLANET_OPS_CLAUDE_PROJECTS_DIR=~/.claude/projects
# PLANET_OPS_WORKSPACES_DIR=~/workspaces
# PLANET_OPS_TOOLS_DIR=~/tools
# PLANET_OPS_CLAUDE_DOCS_DIR=~/claude

# Google Drive shared folder
# PLANET_OPS_GDRIVE_SHARED=~/Library/CloudStorage/GoogleDrive-user@planet.com/Shared drives

# Auth token paths
# PLANET_OPS_GRAFANA_TOKEN_PATH=~/.config/grafana-token
# PLANET_OPS_PAGERDUTY_TOKEN_PATH=~/.config/pagerduty-token

# Polling intervals (seconds)
# PLANET_OPS_POLL_AGENTS=30
# PLANET_OPS_POLL_MRS=120
# PLANET_OPS_POLL_SLACK=300
# PLANET_OPS_POLL_JIRA=300
# PLANET_OPS_POLL_GRAFANA_METRICS=30
# PLANET_OPS_POLL_ONCALL=60
# PLANET_OPS_POLL_WORKTREES=60
